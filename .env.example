# CONTAX - Variables de entorno
# Copiar a .env y completar con valores reales

ENVIRONMENT=production

# PostgreSQL - Railway lo provee automáticamente al agregar el plugin
DATABASE_URL=postgresql://usuario:password@host:5432/contax_db

# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# CORS - dominios permitidos (separados por coma en producción)
CORS_ORIGINS=["https://app.contax.ec","http://localhost:5173"]
